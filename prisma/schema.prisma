generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  staff
  admin
}

model Credential {
  id           String @id @default(uuid())
  role         Role   @unique
  passwordHash String
}

model Table {
  id        String   @id @default(uuid())
  number    Int      @unique
  createdAt DateTime @default(now())
}
