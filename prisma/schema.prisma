generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  staff
  admin
}

model Credential {
  id           String @id @default(uuid())
  role         Role   @unique
  passwordHash String
}

model Table {
  id        String   @id @default(uuid())
  number    Int      @unique
  createdAt DateTime @default(now())
}

model MenuItem {
  id        String   @id @default(uuid())
  name      String
  price     Decimal  @db.Decimal(10, 2)
  available Boolean  @default(true)
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
}
