DATABASE_URL="postgresql://user:password@host:5432/dbname"
AUTH_SECRET="replace-with-a-long-random-string"

# Used only by `prisma/seed.ts` to set the initial staff/admin login passwords.
# Pick your own values — never commit real ones.
SEED_STAFF_PASSWORD="replace-with-a-staff-password"
SEED_ADMIN_PASSWORD="replace-with-an-admin-password"

# Used only by the payment-methods admin QR image upload. Leave blank to skip
# image upload locally — payment methods still work fully via accountInfo text.
# Create a Blob store in the Vercel dashboard (Storage tab) to get a real token.
BLOB_READ_WRITE_TOKEN=""
